<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SG_SGTORNEO_ADOLFO.MVVM.Views"
             x:Class="SG_SGTORNEO_ADOLFO.MVVM.Views.EquiposView">
    <VerticalStackLayout Padding="20" Spacing="20">
        <Button Text="Añadir Equipo"
                Command="{Binding NuevoEquipoCommand}"/>
        <CollectionView ItemsSource="{Binding Equipos}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5" BorderColor="Gray">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding Nombre}" FontAttributes="Bold" FontSize="18"/>
                            <HorizontalStackLayout Spacing="10">
                                <Button Text="Editar"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:EquiposView}},
                                        Path=BindingContext.EditarEquipoCommand}"
                                        CommandParameter="{Binding .}"/>
                                <Button Text="Eliminar"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:EquiposView}},
                                        Path=BindingContext.EliminarEquipoCommand}"
                                        CommandParameter="{Binding .}"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>